@model IEnumerable<LibraryManagement.Domain.Entities.Book>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<style>
    /* Hero Section phong cách Atelier */
    .hero-atelier {
        background: linear-gradient(135deg, #1e1b4b 0%, #3525cd 100%);
        border-radius: 1.5rem;
        position: relative;
        overflow: hidden;
        border: none;
        color: white;
    }

    /* Card Sách tinh chỉnh */
    .book-card-custom {
        border: none;
        border-radius: 1rem;
        transition: all 0.3s ease;
        background: #ffffff;
    }

        .book-card-custom:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(53, 37, 205, 0.12) !important;
        }

    .img-wrapper {
        border-radius: 1rem 1rem 0 0;
        overflow: hidden;
    }

    .btn-atelier-outline {
        border: 1.5px solid #3525cd;
        color: #3525cd;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .btn-atelier-outline:hover {
            background-color: #3525cd;
            color: white;
        }

    .section-headline {
        font-family: 'Manrope', sans-serif;
        font-weight: 800;
        color: #131b2e;
    }
</style>

<div class="hero-atelier p-5 mb-5 shadow-lg">
    <div class="container-fluid py-4">
        <h1 class="display-4 fw-bold font-headline mb-3">📚 Welcome to Library</h1>
        <p class="col-md-8 fs-4 opacity-75 mb-4">Browse our collection and borrow books online.</p>
        <a asp-action="Books" class="btn btn-light btn-lg px-4 fw-bold shadow-sm" style="color: #3525cd; border-radius: 10px;">
            Browse Books
        </a>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-4 px-2">
    <h4 class="section-headline mb-0">Featured Books</h4>
    <a asp-action="Books" class="text-decoration-none fw-bold small text-primary">View All Catalog →</a>
</div>

<div class="row row-cols-2 row-cols-md-4 g-4">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100 book-card-custom shadow-sm">
                <div class="img-wrapper">
                    @if (!string.IsNullOrEmpty(book.CoverImage))
                    {
                        <img src="@book.CoverImage" class="card-img-top"
                             style="height:240px; object-fit:cover;" alt="@book.Title" />
                    }
                    else
                    {
                        <div style="height:240px; background:#f1f5f9;
                                    display:flex; align-items:center;
                                    justify-content:center; color:#94a3b8;">
                            <span class="material-symbols-outlined fs-1">image_not_supported</span>
                        </div>
                    }
                </div>

                <div class="card-body p-3">
                    <h6 class="card-title fw-bold text-dark text-truncate" title="@book.Title">@book.Title</h6>
                    <p class="card-text text-muted small mb-0">
                        @string.Join(", ", book.BookAuthors.Select(ba => ba.Author.Name))
                    </p>
                </div>

                <div class="card-footer bg-transparent border-0 p-3 pt-0">
                    <a asp-action="BookDetail" asp-route-id="@book.Id"
                       class="btn btn-sm btn-atelier-outline w-100 py-2">View Detail</a>
                </div>
            </div>
        </div>
    }
</div>