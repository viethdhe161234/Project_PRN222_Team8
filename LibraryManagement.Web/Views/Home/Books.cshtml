@model LibraryManagement.Web.Models.BookListViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Books";
}

<div class="row">
    <!-- Sidebar filter -->
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-header">Search</div>
            <div class="card-body">
                <form method="get" asp-action="Books">
                    <input type="text" name="searchTerm" value="@Model.SearchTerm"
                           class="form-control mb-2" placeholder="Search title, author..." />
                    <select name="categoryId" class="form-select mb-2">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Categories)
                        {
                            @if (Model.CategoryId == cat.Id)
                            {
                                <option value="@cat.Id" selected>@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.CategoryId.HasValue)
                    {
                        <a asp-action="Books" class="btn btn-outline-secondary w-100 mt-1">Clear</a>
                    }
                </form>
            </div>
        </div>
    </div>

    <!-- Book list -->
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Books</h4>
            <small class="text-muted">@Model.Books.Count() results</small>
        </div>

        @if (!Model.Books.Any())
        {
            <div class="alert alert-info">No books found.</div>
        }
        else
        {
            <div class="row row-cols-2 row-cols-md-3 g-4">
                @foreach (var book in Model.Books)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(book.CoverImage))
                            {
                                <img src="@book.CoverImage" class="card-img-top"
                                     style="height:180px; object-fit:cover;" alt="@book.Title" />
                            }
                            else
                            {
                                <div style="height:180px; background:#e5e7eb;
                                            display:flex; align-items:center;
                                            justify-content:center; color:#9ca3af;">
                                    No image
                                </div>
                            }
                            <div class="card-body">
                                <h6 class="card-title">@book.Title</h6>
                                <p class="card-text text-muted small">
                                    @string.Join(", ", book.BookAuthors.Select(ba => ba.Author.Name))
                                </p>
                                <p class="card-text">
                                    @foreach (var bc in book.BookCategories)
                                    {
                                        <span class="badge bg-secondary me-1">@bc.Category.Name</span>
                                    }
                                </p>
                            </div>
                            <div class="card-footer">
                                <a asp-action="BookDetail" asp-route-id="@book.Id"
                                   class="btn btn-sm btn-outline-primary w-100">View Detail</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>