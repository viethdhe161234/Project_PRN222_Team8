@model LibraryManagement.Web.Models.BookListViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Books";
}

<style>
    /* Nâng cấp Sidebar Filter */
    .filter-card {
        border: none;
        border-radius: 1rem;
        background: #ffffff;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

        .filter-card .card-header {
            background: transparent;
            border-bottom: 1px solid #f1f5f9;
            font-family: 'Manrope', sans-serif;
            font-weight: 700;
            color: #131b2e;
            padding: 1.25rem;
        }

    .form-control, .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3525cd;
            box-shadow: 0 0 0 3px rgba(53, 37, 205, 0.1);
        }

    /* Book Card Styling (Đồng bộ với trang Home) */
    .book-card {
        border: none;
        border-radius: 1rem;
        transition: all 0.3s ease;
        background: #ffffff;
    }

        .book-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(53, 37, 205, 0.1) !important;
        }

    .book-cover-container {
        border-radius: 1rem 1rem 0 0;
        overflow: hidden;
        height: 220px;
        position: relative;
    }

    .badge-category {
        background: #eef0ff;
        color: #3525cd;
        font-weight: 600;
        font-size: 0.7rem;
        border: none;
        padding: 0.4rem 0.7rem;
    }

    .results-count {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 500;
    }
</style>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card filter-card sticky-top" style="top: 100px; z-index: 10;">
            <div class="card-header d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">tune</span>
                Refine Search
            </div>
            <div class="card-body p-4">
                <form method="get" asp-action="Books">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Keywords</label>
                        <input type="text" name="searchTerm" value="@Model.SearchTerm"
                               class="form-control" placeholder="Title, author..." />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All Categories</option>
                            @foreach (var cat in Model.Categories)
                            {
                                @if (Model.CategoryId == cat.Id)
                                {
                                    <option value="@cat.Id" selected>@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-indigo w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                        <span class="material-symbols-outlined fs-5">search</span> Search
                    </button>

                    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.CategoryId.HasValue)
                    {
                        <a asp-action="Books" class="btn btn-outline-light text-muted w-100 mt-2 btn-sm fw-bold">
                            Reset Filters
                        </a>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
            <h4 class="font-headline fw-800 mb-0">Library Catalog</h4>
            <span class="results-count">Showing <strong>@Model.Books.Count()</strong> volumes</span>
        </div>

        @if (!Model.Books.Any())
        {
            <div class="text-center py-5">
                <span class="material-symbols-outlined display-1 text-light mb-3">search_off</span>
                <h5 class="text-muted">No volumes found matching your criteria.</h5>
                <p class="small text-secondary">Try adjusting your filters or search terms.</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
                @foreach (var book in Model.Books)
                {
                    <div class="col">
                        <div class="card h-100 book-card shadow-sm">
                            <div class="book-cover-container">
                                @if (!string.IsNullOrEmpty(book.CoverImage))
                                {
                                    <img src="@book.CoverImage" class="card-img-top w-100 h-100"
                                         style="object-fit:cover;" alt="@book.Title" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-light text-muted opacity-50">
                                        <span class="material-symbols-outlined fs-1">book</span>
                                        <span class="small mt-2">No Cover</span>
                                    </div>
                                }
                            </div>

                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="fw-bold text-dark mb-1 text-truncate">@book.Title</h6>
                                <p class="small text-secondary mb-2">
                                    by @string.Join(", ", book.BookAuthors.Select(ba => ba.Author.Name))
                                </p>

                                <div class="mb-3 mt-auto">
                                    @foreach (var bc in book.BookCategories)
                                    {
                                        <span class="badge badge-category rounded-pill me-1">@bc.Category.Name</span>
                                    }
                                </div>

                                <a asp-action="BookDetail" asp-route-id="@book.Id"
                                   class="btn btn-sm btn-outline-primary w-100 py-2 fw-bold"
                                   style="border-radius: 8px;">View Details</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>