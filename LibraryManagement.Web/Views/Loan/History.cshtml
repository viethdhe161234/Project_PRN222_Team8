@model IEnumerable<LibraryManagement.Domain.Entities.Loan>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Loan History";
    var returned = Model.Where(l => l.ReturnDate != null).ToList();
    var active = Model.Where(l => l.ReturnDate == null).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Loan History</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Current Loans</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="card border-0 bg-light text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-semibold">@Model.Count()</div>
                <small class="text-muted">Total</small>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 bg-light text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-semibold text-success">@returned.Count</div>
                <small class="text-muted">Returned</small>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 bg-light text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-semibold text-primary">@active.Count</div>
                <small class="text-muted">Active</small>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No loan history found.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Book</th>
                        <th>Borrow Date</th>
                        <th>Due Date</th>
                        <th>Return Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@loan.BookCopy?.BookEdition?.Book?.Title</div>
                                <small class="text-muted">@loan.BookCopy?.BookEdition?.Publisher</small>
                            </td>
                            <td>@loan.BorrowDate.ToString("dd/MM/yyyy")</td>
                            <td class="@(loan.IsOverdue ? "text-danger fw-semibold" : "")">
                                @loan.DueDate.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                @(loan.ReturnDate.HasValue ? loan.ReturnDate.Value.ToString("dd/MM/yyyy") : "—")
                            </td>
                            <td>
                                @if (loan.ReturnDate.HasValue)
                                {
                                    if (loan.ReturnDate.Value > loan.DueDate)
                                    {
                                        var lateDays = (int)(loan.ReturnDate.Value - loan.DueDate).TotalDays;
                                        <span class="badge bg-warning text-dark">Returned late (@lateDays d)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Returned on time</span>
                                    }
                                }
                                else if (loan.IsOverdue)
                                {
                                    <span class="badge bg-danger">Overdue @loan.OverdueDays day(s)</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Active</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
