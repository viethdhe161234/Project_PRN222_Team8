@model IEnumerable<LibraryManagement.Domain.Entities.Loan>

@{
    Layout = "_LibrarianLayout";
    ViewData["Title"] = "Active Loans";
    var overdueCount = Model.Count(l => l.IsOverdue);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Active Loans</h5>
    @if (overdueCount > 0)
    {
        <a asp-action="OverdueLoans" class="btn btn-sm btn-danger">
            ⚠️ Overdue <span class="badge bg-white text-danger ms-1">@overdueCount</span>
        </a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Member</th>
                    <th>Book</th>
                    <th>Barcode</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in Model)
                {
                    <tr class="@(loan.IsOverdue ? "table-danger" : "")">
                        <td>@loan.Member.FullName</td>
                        <td>@loan.BookCopy.BookEdition.Book.Title</td>
                        <td><code>@loan.BookCopy.Barcode</code></td>
                        <td>@loan.BorrowDate.ToString("dd/MM/yyyy")</td>
                        <td class="@(loan.IsOverdue ? "text-danger fw-semibold" : "")">
                            @loan.DueDate.ToString("dd/MM/yyyy")
                        </td>
                        <td>
                            @if (loan.IsOverdue)
                            {
                                <span class="badge bg-danger">Overdue @loan.OverdueDays d</span>
                            }
                            else
                            {
                                var daysLeft = (loan.DueDate - DateTime.Now).Days;
                                if (daysLeft <= 3)
                                {
                                    <span class="badge bg-warning text-dark">Due soon (@daysLeft d)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active (@daysLeft d left)</span>
                                }
                            }
                        </td>
                        <td>
                            <form asp-action="ConfirmReturn"
                                  asp-route-loanId="@loan.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Confirm return?')">
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    Confirm Return
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-3">No active loans</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
