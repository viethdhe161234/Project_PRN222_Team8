@model IEnumerable<LibraryManagement.Domain.Entities.Loan>

@{
    Layout = "_LibrarianLayout";
    ViewData["Title"] = "Active Loans";
    var overdueCount = Model.Count(l => l.IsOverdue);
}

<style>
    .loan-card {
        border: none;
        border-radius: 0.75rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        background: #fff;
    }

    .table thead th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1rem;
        border: none;
    }

    .table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.9rem;
    }

    .status-badge {
        font-weight: 700;
        font-size: 0.7rem;
        padding: 0.5em 0.8em;
        border-radius: 6px;
    }

    .barcode-chip {
        background: #f1f5f9;
        color: #475569;
        padding: 2px 8px;
        border-radius: 4px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
    }

    .member-name {
        color: #1e293b;
        font-weight: 600;
        display: block;
    }
</style>

@* Alerts: Giữ nguyên TempData *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: 10px;">
        <span class="material-symbols-outlined align-middle fs-5 me-2">check_circle</span> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 10px;">
        <span class="material-symbols-outlined align-middle fs-5 me-2">error</span> @TempData["Error"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-800 text-dark mb-0">Active Loans</h4>
        <p class="text-muted small mb-0">Manage and confirm book returns from members.</p>
    </div>

    @if (overdueCount > 0)
    {
        <a asp-action="OverdueLoans" class="btn btn-danger shadow-sm d-flex align-items-center gap-2" style="border-radius: 8px;">
            <span class="material-symbols-outlined fs-5">warning</span>
            <span>Overdue</span>
            <span class="badge bg-white text-danger">@overdueCount</span>
        </a>
    }
</div>

<div class="card loan-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Book & Barcode</th>
                        <th>Dates</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in Model)
                    {
                        <tr class="@(loan.IsOverdue ? "table-danger opacity-transition" : "")">
                            <td>
                                <span class="member-name">@loan.Member.FullName</span>
                                <small class="text-muted">ID: #@loan.MemberId</small>
                            </td>
                            <td>
                                <div class="fw-bold text-dark mb-1">@loan.BookCopy.BookEdition.Book.Title</div>
                                <span class="barcode-chip">@loan.BookCopy.Barcode</span>
                            </td>
                            <td>
                                <div class="small mb-1">
                                    <span class="text-muted">Borrowed:</span> @loan.BorrowDate.ToString("dd/MM/yyyy")
                                </div>
                                <div class="small @(loan.IsOverdue ? "text-danger fw-bold" : "text-muted")">
                                    <span class="text-muted">Due:</span> @loan.DueDate.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            <td>
                                @if (loan.IsOverdue)
                                {
                                    <span class="badge bg-danger status-badge">Overdue @loan.OverdueDays d</span>
                                }
                                else
                                {
                                    var daysLeft = (loan.DueDate - DateTime.Now).Days;
                                    if (daysLeft <= 3)
                                    {
                                        <span class="badge bg-warning text-dark status-badge">Due soon (@daysLeft d)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success status-badge">Active (@daysLeft d left)</span>
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ConfirmReturn"
                                      asp-route-loanId="@loan.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Confirm return for: @loan.BookCopy.BookEdition.Book.Title?')">
                                    <button type="submit" class="btn btn-sm btn-primary px-3 fw-bold" style="border-radius: 6px;">
                                        Confirm Return
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <div class="opacity-50 mb-2">
                                    <span class="material-symbols-outlined fs-1">inventory_2</span>
                                </div>
                                No active loans found at the moment.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>