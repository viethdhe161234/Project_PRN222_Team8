@model LibraryManagement.Web.Models.OverdueLoanViewModel

@{
    Layout = "_LibrarianLayout";
    ViewData["Title"] = "Overdue Loans";
}

<style>
    .overdue-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 4px 20px rgba(220, 53, 69, 0.08);
        overflow: hidden;
    }

    .table-overdue thead th {
        background-color: #fff5f5;
        color: #b91c1c;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1rem;
        border-bottom: 2px solid #fee2e2;
    }

    .row-overdue {
        background-color: #fffafa !important;
        transition: all 0.2s;
    }

        .row-overdue:hover {
            background-color: #fee2e2 !important;
        }

    .days-badge {
        background: #dc3545;
        color: white;
        padding: 0.5rem 0.8rem;
        border-radius: 20px;
        font-weight: 800;
        font-size: 0.75rem;
        box-shadow: 0 4px 10px rgba(220, 53, 69, 0.2);
    }

    .member-info {
        display: flex;
        flex-direction: column;
    }

        .member-info strong {
            color: #1e293b;
            font-size: 0.95rem;
        }

        .member-info small {
            color: #64748b;
        }

    .alert-modern {
        border: none;
        border-radius: 0.75rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }
</style>

<div class="mb-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-modern shadow-sm">
            <span class="material-symbols-outlined">check_circle</span>
            <div class="fw-semibold">@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-modern shadow-sm">
            <span class="material-symbols-outlined">error</span>
            <div class="fw-semibold">@TempData["Error"]</div>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-800 text-dark mb-0 d-flex align-items-center gap-2">
            Overdue Loans
            @if (Model.TotalOverdue > 0)
            {
                <span class="badge bg-danger rounded-pill">@Model.TotalOverdue</span>
            }
        </h4>
        <p class="text-muted small mb-0">List of books that have exceeded their return deadline.</p>
    </div>
    <a asp-action="ActiveLoans" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1 fw-bold px-3">
        <span class="material-symbols-outlined fs-6">arrow_back</span> Back to Active
    </a>
</div>

@if (!Model.Loans.Any())
{
    <div class="alert alert-success alert-modern border-0 bg-success-subtle text-success py-4 shadow-sm">
        <span class="material-symbols-outlined fs-1">verified</span>
        <div>
            <h5 class="fw-bold mb-1">Excellent!</h5>
            <p class="mb-0">All members are returning books on time. No overdue loans found.</p>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger alert-modern border-0 bg-danger-subtle text-danger mb-4 shadow-sm">
        <span class="material-symbols-outlined fs-2">notification_important</span>
        <div class="fw-bold">
            Attention: @Model.TotalOverdue loan(s) are overdue. Action required.
        </div>
    </div>

    <div class="card overdue-card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-overdue mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Member</th>
                            <th>Book Details</th>
                            <th>Borrow Info</th>
                            <th>Overdue Duration</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var loan in Model.Loans)
                        {
                            <tr class="row-overdue">
                                <td class="ps-4">
                                    <div class="member-info">
                                        <strong>@loan.Member?.FullName</strong>
                                        <small><span class="material-symbols-outlined align-middle fs-6">mail</span> @loan.Member?.Account?.Email</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@loan.BookCopy?.BookEdition?.Book?.Title</div>
                                    <small class="text-muted">
                                        @loan.BookCopy?.BookEdition?.Publisher (@loan.BookCopy?.BookEdition?.PublishYear)
                                    </small>
                                </td>
                                <td>
                                    <div class="small">Borrowed: <strong>@loan.BorrowDate.ToString("dd/MM/yyyy")</strong></div>
                                    <div class="small text-danger">Deadline: <strong>@loan.DueDate.ToString("dd/MM/yyyy")</strong></div>
                                </td>
                                <td>
                                    <span class="days-badge">
                                        @loan.OverdueDays days late
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-action="ConfirmReturn" asp-route-loanId="@loan.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Confirm return for: @loan.BookCopy?.BookEdition?.Book?.Title?')">
                                        <button type="submit" class="btn btn-sm btn-primary fw-bold px-3">
                                            Confirm Return
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}