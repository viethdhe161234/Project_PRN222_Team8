@model LibraryManagement.Web.Models.OverdueLoanViewModel

@{
    Layout = "_LibrarianLayout";
    ViewData["Title"] = "Overdue Loans";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
        Overdue Loans
        @if (Model.TotalOverdue > 0)
        {
            <span class="badge bg-danger ms-2">@Model.TotalOverdue</span>
        }
    </h5>
    <a asp-action="ActiveLoans" class="btn btn-sm btn-outline-secondary">&larr; Back to Active Loans</a>
</div>

@if (!Model.Loans.Any())
{
    <div class="alert alert-success">
        ✅ No overdue loans — all members are returning books on time!
    </div>
}
else
{
    <div class="alert alert-danger">
        ⚠️ <strong>@Model.TotalOverdue loan(s)</strong> are overdue. Please follow up with the members below.
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Member</th>
                        <th>Book</th>
                        <th>Borrow Date</th>
                        <th>Due Date</th>
                        <th>Days Overdue</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in Model.Loans)
                    {
                        <tr class="table-danger">
                            <td>@loan.Id</td>
                            <td>
                                <div class="fw-semibold">@loan.Member?.FullName</div>
                                <small class="text-muted">@loan.Member?.Account?.Email</small>
                            </td>
                            <td>
                                <div>@loan.BookCopy?.BookEdition?.Book?.Title</div>
                                <small class="text-muted">
                                    @loan.BookCopy?.BookEdition?.Publisher (@loan.BookCopy?.BookEdition?.PublishYear)
                                </small>
                            </td>
                            <td>@loan.BorrowDate.ToString("dd/MM/yyyy")</td>
                            <td class="fw-semibold text-danger">@loan.DueDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-danger">@loan.OverdueDays day(s)</span>
                            </td>
                            <td>
                                <form asp-action="ConfirmReturn" asp-route-loanId="@loan.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Confirm return for this book?')">
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        Confirm Return
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
