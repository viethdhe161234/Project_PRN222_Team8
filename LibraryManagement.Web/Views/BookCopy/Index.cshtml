@model IEnumerable<LibraryManagement.Domain.Entities.BookCopy>

@{
    Layout = "_AdminLayout";
    var edition = ViewBag.Edition as LibraryManagement.Domain.Entities.BookEdition;
    ViewData["Title"] = $"Copies — {edition?.Publisher} {edition?.PublishYear}";
}

<style>
    /* CSS hỗ trợ icon Material */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
    }

    /* Thiết kế bảng dòng tách rời */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }

        .table-custom tbody tr {
            transition: background-color 0.2s ease;
        }

            .table-custom tbody tr:hover {
                background-color: #f8f9fa;
            }

        .table-custom td {
            border-top: 1px solid #f1f3f5;
            border-bottom: 1px solid #f1f3f5;
            padding: 1rem;
            vertical-align: middle;
        }

            .table-custom td:first-child {
                border-left: 1px solid #f1f3f5;
                border-top-left-radius: 0.75rem;
                border-bottom-left-radius: 0.75rem;
            }

            .table-custom td:last-child {
                border-right: 1px solid #f1f3f5;
                border-top-right-radius: 0.75rem;
                border-bottom-right-radius: 0.75rem;
            }

    /* Form input custom */
    .form-control-custom {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        font-size: 1rem;
        font-weight: 500;
        color: #212529;
        transition: all 0.2s ease-in-out;
    }

        .form-control-custom:focus {
            background-color: #ffffff;
            border-color: #3525cd;
            box-shadow: 0 0 0 0.25rem rgba(53, 37, 205, 0.15);
            outline: 0;
        }

    .action-btns {
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .table-custom tbody tr:hover .action-btns {
        opacity: 1;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav class="d-flex gap-2 text-uppercase text-muted fw-bold mb-1" style="font-size: 0.75rem; letter-spacing: 0.1em;">
           
            <a asp-controller="Book" asp-action="Index" class="text-decoration-none text-muted" onmouseover="this.style.color='#3525cd'" onmouseout="this.style.color='#6c757d'" style="transition: color 0.2s;">Books</a>
            <span class="text-secondary">/</span>
            <span style="color: #3525cd !important;">Inventory Copies</span>
        </nav>
        <h2 class="fw-bold mb-1 text-dark" style="font-size: 1.75rem; letter-spacing: -0.02em;">Inventory Copies</h2>
        <p class="text-muted mb-0 fw-medium">Edition: @edition?.Publisher — @edition?.PublishYear</p>
    </div>
    <a asp-controller="Book" asp-action="Detail" asp-route-id="@edition?.BookId" class="btn btn-light px-3 py-2 fw-semibold rounded-2 d-flex align-items-center gap-2 border shadow-sm" style="font-size: 0.95rem;">
        <span class="material-symbols-outlined" style="font-size: 1.2rem;">arrow_back</span>
        Back to Book Profile
    </a>
</div>

<div class="mb-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-success py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #e6f8f0; color: #005236;">
            <span class="material-symbols-outlined fs-4">check_circle</span>
            <div class="fw-medium mb-0">@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-danger py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #ffdad6; color: #93000a;">
            <span class="material-symbols-outlined fs-4 text-danger">error</span>
            <div class="fw-medium mb-0">@TempData["Error"]</div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4" style="background-color: #ffffff; max-width: 600px;">
    <div class="card-body p-3 d-flex align-items-center gap-3">
        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background-color: #e2dfff; color: #3525cd;">
            <span class="material-symbols-outlined fs-4">barcode_scanner</span>
        </div>
        <form asp-action="Create" method="post" class="d-flex gap-2 flex-grow-1 m-0">
            <input type="hidden" name="EditionId" value="@edition?.Id" />
            <div class="flex-grow-1">
                <input type="text" name="Barcode" class="form-control form-control-custom rounded-3 shadow-none w-100" placeholder="Scan or enter barcode (e.g. LIB-0001)" required autocomplete="off" />
            </div>
            <button type="submit" class="btn px-4 fw-semibold rounded-3 d-flex align-items-center gap-2 text-white shadow-sm" style="background-color: #3525cd; transition: all 0.2s;" onmouseover="this.style.filter='brightness(0.9)'" onmouseout="this.style.filter='brightness(1)'">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">add</span>
                Add
            </button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4" style="background-color: #fcfcff;">
    <div class="card-body p-3">
        <table class="table table-borderless table-custom mb-0">
            <thead>
                <tr class="text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    <th class="px-4">Barcode Identifier</th>
                    <th class="px-3 text-center" style="width: 150px;">Status</th>
                    <th class="px-4 text-end" style="width: 120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="px-4 py-5 text-center text-muted bg-white rounded-3">
                            <span class="material-symbols-outlined fs-1 mb-2 opacity-50">qr_code_scanner</span>
                            <p class="mb-0 fw-medium">No physical copies recorded for this edition.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var copy in Model)
                    {
                        <tr class="bg-white">
                            <td class="px-4">
                                <span class="fw-bold text-dark px-2 py-1 rounded" style="font-family: 'Courier New', Courier, monospace; font-size: 1rem; background-color: #f8f9fa; border: 1px solid #e9ecef;">
                                    @copy.Barcode
                                </span>
                            </td>

                            <td class="px-3 text-center">
                                @if (copy.IsAvailable)
                                {
                                    <span class="badge rounded-pill fw-bold px-3 py-2" style="background-color: #d1fae5; color: #065f46; border: 1px solid #a7f3d0;">
                                        <span class="material-symbols-outlined d-inline-block align-middle me-1" style="font-size: 0.9rem;">check_circle</span>
                                        Available
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill fw-bold px-3 py-2" style="background-color: #fef3c7; color: #92400e; border: 1px solid #fde68a;">
                                        <span class="material-symbols-outlined d-inline-block align-middle me-1" style="font-size: 0.9rem;">person_book</span>
                                        Borrowed
                                    </span>
                                }
                            </td>

                            <td class="px-4 text-end">
                                @if (copy.IsAvailable)
                                {
                                    <div class="action-btns d-flex justify-content-end">
                                        <form asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Are you sure you want to remove this copy from inventory?')">
                                            <input type="hidden" name="id" value="@copy.Id" />
                                            <input type="hidden" name="editionId" value="@edition?.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border p-0"
                                                    style="width: 36px; height: 36px; background-color: #ffffff; color: #dc3545; border-color: #f8d7da !important; transition: all 0.2s;"
                                                    onmouseover="this.style.backgroundColor='#fff5f5'; this.style.color='#bd2130';"
                                                    onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#dc3545';"
                                                    title="Delete Copy">
                                                <span class="material-symbols-outlined" style="font-size: 1.1rem;">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-end gap-1 text-muted" title="Cannot delete currently borrowed book">
                                        <span class="material-symbols-outlined" style="font-size: 1.1rem;">lock</span>
                                        <span class="small fw-medium">Locked</span>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>