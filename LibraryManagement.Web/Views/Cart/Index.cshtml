@model LibraryManagement.Web.Models.CartViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "My Cart";
}

<style>
    .cart-table-card {
        border: none;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        background: white;
    }

    .table thead th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding: 1rem;
        border: none;
    }

    .table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }

    .book-cover-mini {
        width: 45px;
        height: 65px;
        object-fit: cover;
        border-radius: 4px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .btn-checkout {
        background-color: #3525cd;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        transition: all 0.2s;
    }

        .btn-checkout:hover {
            background-color: #2a1da8;
            transform: translateY(-2px);
        }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: 10px;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 10px;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
    </div>
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="fw-800 font-headline mb-1">My Cart</h3>
        <p class="text-muted small mb-0">Review the books you want to borrow.</p>
    </div>
    <div class="text-end">
        <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 8px;">
            <span class="fw-bold text-primary">@Model.Items.Count</span> / @Model.MaxBooksPerRequest books
        </span>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-dashed">
        <div class="mb-3 opacity-25">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-cart-x" viewBox="0 0 16 16">
                <path d="M7.354 5.646a.5.5 0 1 0-.708.708L7.793 7.5 6.646 8.646a.5.5 0 1 0 .708.708L8.5 8.207l1.146 1.147a.5.5 0 0 0 .708-.708L9.207 7.5l1.147-1.146a.5.5 0 0 0-.708-.708L8.5 6.793z" />
                <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
            </svg>
        </div>
        <h5 class="text-muted">Your cart is empty.</h5>
        <a asp-controller="Home" asp-action="Books" class="btn btn-primary mt-2 rounded-pill px-4">Browse books</a>
    </div>
}
else
{
    <div class="cart-table-card mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Cover</th>
                        <th>Book Details</th>
                        <th>Edition</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.CoverImage))
                                {
                                    <img src="@item.CoverImage" alt="cover" class="book-cover-mini" />
                                }
                                else
                                {
                                    <div class="book-cover-mini bg-light d-flex align-items-center justify-content-center text-muted" style="font-size: 8px; text-align: center;">
                                        No img
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.BookTitle</div>
                            </td>
                            <td>
                                <span class="text-muted small">@item.Publisher</span>
                                <span class="badge bg-light text-muted border ms-1">@item.PublishYear</span>
                            </td>
                            <td class="text-end">
                                <form asp-action="Remove" method="post" class="d-inline">
                                    <input type="hidden" name="editionId" value="@item.EditionId" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none fw-bold">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-end align-items-center">
        @* Logic Clear Cart: Giữ nguyên form và confirm *@
        <form asp-action="Clear" method="post">
            <button type="submit" class="btn btn-link text-secondary text-decoration-none fw-bold"
                    onclick="return confirm('Clear cart?')">
                Clear Cart
            </button>
        </form>

        @* Logic Submit: Giữ nguyên controller và confirm *@
        <form asp-controller="BorrowRequest" asp-action="Checkout" method="post">
            <button type="submit" class="btn btn-primary btn-checkout"
                    onclick="return confirm('Submit borrow request?')">
                📋 Submit Borrow Request
            </button>
        </form>
    </div>
}