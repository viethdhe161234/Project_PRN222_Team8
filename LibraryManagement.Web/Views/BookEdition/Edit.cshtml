@model LibraryManagement.Web.Models.BookEditionViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Edition";
}

<div class="card" style="max-width: 500px;">
    <div class="card-header">Edit Edition</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="Id" type="hidden" />
            <input asp-for="BookId" type="hidden" />

            <div class="mb-3">
                <label asp-for="Publisher" class="form-label"></label>
                <input asp-for="Publisher" class="form-control" />
                <span asp-validation-for="Publisher" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PublishYear" class="form-label"></label>
                <input asp-for="PublishYear" type="number" class="form-control" />
                <span asp-validation-for="PublishYear" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-controller="Book" asp-action="Detail" asp-route-id="@Model.BookId"
               class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}