@model LibraryManagement.Web.Models.AccountIndexViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Accounts";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Accounts</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Staff</a>
</div>

<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="searchTerm" value="@Model.SearchTerm"
               class="form-control" placeholder="Search username, email, name..." />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var account in Model.Accounts)
                {
                    <tr>
                        <td>@account.Username</td>
                        <td>@account.Email</td>
                        <td>
                            <span class="badge @(account.Role.Name == "Manager" ? "bg-danger" :
                                               account.Role.Name == "Librarian" ? "bg-warning text-dark" :
                                               "bg-secondary")">
                                @account.Role.Name
                            </span>
                        </td>
                        <td>
                            <span class="badge @(account.IsActive ? "bg-success" : "bg-secondary")">
                                @(account.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="d-flex gap-1">
                            @* View Member — tất cả *@
                            <a asp-controller="Member" asp-action="Edit"
                               asp-route-id="@account.MemberId"
                               class="btn btn-sm btn-outline-info">Member</a>

                            @* Activate/Deactivate — tất cả *@
                            @if (account.IsActive)
                            {
                                <form asp-action="SetActive" asp-route-id="@account.Id"
                                      asp-route-isActive="false" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Deactivate</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="SetActive" asp-route-id="@account.Id"
                                      asp-route-isActive="true" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">Activate</button>
                                </form>
                            }

                            @* Edit + Delete — chỉ Manager/Librarian *@
                            @if (account.Role.Name != "User")
                            {
                                <a asp-action="Edit" asp-route-id="@account.Id"
                                   class="btn btn-sm btn-outline-primary">Edit</a>
                                <form asp-action="Delete" asp-route-id="@account.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this account and linked member?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Accounts.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No accounts found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>