@model LibraryManagement.Web.Models.ResetPasswordViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Reset Password";
}

<style>
    .auth-card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        background: #ffffff;
        overflow: hidden;
    }

    .auth-header {
        background: #f8fafc;
        padding: 2.5rem 2rem 1.5rem;
        text-align: center;
    }

    .auth-body {
        padding: 1rem 2.5rem 2.5rem;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .form-control {
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #3525cd;
            box-shadow: 0 0 0 4px rgba(53, 37, 205, 0.1);
        }

    .btn-auth {
        background-color: #3525cd;
        border: none;
        border-radius: 0.75rem;
        padding: 0.8rem;
        font-weight: 700;
        transition: all 0.2s;
    }

        .btn-auth:hover {
            background-color: #2a1da8;
            transform: translateY(-1px);
        }
</style>

<div class="container py-5">
    <div class="card auth-card mx-auto" style="max-width: 450px;">
        <div class="auth-header">
            <div class="mb-3 text-primary">
                <span class="material-symbols-outlined fs-1">lock_open</span>
            </div>
            <h4 class="fw-800 font-headline mb-1">Set New Password</h4>
            <p class="text-muted small mb-0">Please enter your new security credentials below.</p>
        </div>

        <div class="auth-body">
            <form asp-action="ResetPassword" method="post">
                @* Giữ nguyên logic validation summary *@
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                @* Giữ nguyên Token hidden *@
                <input asp-for="Token" type="hidden" />

                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-auth w-100">
                    Reset Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* Giữ nguyên phần script validation của bạn *@
    @await Html.PartialAsync("_ValidationScriptsPartial")
}