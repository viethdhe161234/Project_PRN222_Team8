@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<style>
    .auth-card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        background: #ffffff;
        overflow: hidden;
    }

    .auth-header {
        background: #f8fafc;
        padding: 2.5rem 2rem 1rem;
        text-align: center;
    }

    .auth-body {
        padding: 1rem 2.5rem 2.5rem;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .form-control {
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }

        .form-control:focus {
            border-color: #3525cd;
            box-shadow: 0 0 0 4px rgba(53, 37, 205, 0.1);
        }

    .btn-auth {
        background-color: #3525cd;
        border: none;
        border-radius: 0.75rem;
        padding: 0.8rem;
        font-weight: 700;
        transition: all 0.2s;
    }

        .btn-auth:hover {
            background-color: #2a1da8;
            transform: translateY(-1px);
        }

    .text-indigo {
        color: #3525cd;
        font-weight: 600;
        text-decoration: none;
    }

        .text-indigo:hover {
            text-decoration: underline;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card auth-card">
                <div class="auth-header">
                    <div class="mb-3 text-primary">
                        <span class="material-symbols-outlined fs-1">person_add</span>
                    </div>
                    <h3 class="fw-800 font-headline mb-1">Create Account</h3>
                    <p class="text-muted small mb-0">Join our library community today.</p>
                </div>

                <div class="auth-body">
                    <form asp-action="Register" method="post">
                        @* Giữ nguyên logic validation summary *@
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label"></label>
                            <input asp-for="Username" class="form-control" placeholder="Choose a username" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-auth w-100 mb-3">Register</button>

                        <div class="text-center">
                            <a asp-action="Login" class="text-indigo small">
                                Already have an account? <span class="fw-800">Login</span>
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Giữ nguyên script validation *@
    @await Html.PartialAsync("_ValidationScriptsPartial")
}