@{
    Layout = "_Layout";
    ViewData["Title"] = "Forgot Password";
}

<style>
    .auth-card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        background: #ffffff;
        overflow: hidden;
    }

    .auth-header {
        background: #f8fafc;
        padding: 2rem 2rem 1rem;
        border-bottom: none;
        text-align: center;
    }

    .auth-body {
        padding: 1rem 2.5rem 2.5rem;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .form-control {
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #3525cd;
            box-shadow: 0 0 0 4px rgba(53, 37, 205, 0.1);
        }

    .btn-auth {
        background-color: #3525cd;
        border: none;
        border-radius: 0.75rem;
        padding: 0.8rem;
        font-weight: 700;
        transition: all 0.2s;
    }

        .btn-auth:hover {
            background-color: #2a1da8;
            transform: translateY(-1px);
        }
</style>

<div class="container py-5">
    <div class="card auth-card mx-auto" style="max-width: 450px;">
        <div class="auth-header">
            <div class="mb-3 text-primary">
                <span class="material-symbols-outlined fs-1">lock_reset</span>
            </div>
            <h4 class="fw-800 font-headline mb-0">Forgot Password?</h4>
        </div>

        <div class="auth-body">
            <p class="text-muted text-center small mb-4">
                No worries! Enter your email address below and we'll send you a link to reset your password.
            </p>

            <form asp-action="ForgotPassword" method="post">
                @* Giữ nguyên logic validation summary của bạn *@
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="mb-4">
                    <label class="form-label">Email Address</label>
                    @* Giữ nguyên name="email" để Controller nhận diện *@
                    <input type="email" name="email" class="form-control"
                           placeholder="name@example.com" required />
                </div>

                <button type="submit" class="btn btn-primary btn-auth w-100 mb-3">
                    Send Reset Link
                </button>

                <div class="text-center">
                    @* Giữ nguyên action Login *@
                    <a asp-action="Login" class="text-decoration-none small fw-bold text-indigo">
                        <span class="material-symbols-outlined fs-6 align-middle me-1">arrow_back</span>
                        Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>