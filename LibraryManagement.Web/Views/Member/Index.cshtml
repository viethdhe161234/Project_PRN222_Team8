@model IEnumerable<LibraryManagement.Domain.Entities.Member>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Members";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<h4 class="mb-3">Members</h4>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Full Name</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model)
                {
                    <tr>
                        <td>@member.FullName</td>
                        <td>@(member.Phone ?? "—")</td>
                        <td>@(member.Address ?? "—")</td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@member.Id"
                               class="btn btn-sm btn-outline-info">Detail</a>
                            @if (member.Account?.Role.Name != "User")
                            {
                                <a asp-action="Edit" asp-route-id="@member.Id"
                                   class="btn btn-sm btn-outline-primary">Edit</a>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No members found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>