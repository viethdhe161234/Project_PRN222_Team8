@model IEnumerable<LibraryManagement.Domain.Entities.Member>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Members";
}

<style>
    /* CSS hỗ trợ icon Material */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
    }

    /* Bảng Modern phong cách Curation */
    .table-modern {
        border-collapse: separate;
        border-spacing: 0;
        width: 100%;
    }

        .table-modern thead th {
            background-color: #f8f9fa;
            color: #6c757d;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 800;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #edf2f7;
        }

        .table-modern tbody td {
            padding: 1.25rem 1.5rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f3f5;
            color: #2d3748;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .table-modern tbody tr:hover td {
            background-color: #fcfaff;
        }

    /* Avatar tròn với dải màu gradient nhẹ */
    .avatar-circle {
        width: 42px;
        height: 42px;
        border-radius: 12px; /* Chuyển sang bo góc hiện đại thay vì tròn hẳn */
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        color: #3525cd;
        background: linear-gradient(135deg, #e2dfff 0%, #efedff 100%);
        font-size: 1rem;
        flex-shrink: 0;
        border: 1px solid rgba(53, 37, 205, 0.1);
    }

    /* Badge cho Role */
    .badge-role {
        padding: 0.4em 1em;
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

        .badge-role.admin {
            background-color: #fff4e5;
            color: #b45309;
        }

        .badge-role.user {
            background-color: #f1f3f5;
            color: #4a5568;
        }

    /* Nút thao tác tinh tế */
    .action-btn {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s;
        color: #718096;
        border: 1px solid transparent;
        background: transparent;
    }

        .action-btn:hover {
            background-color: #ffffff;
            border-color: #e2e8f0;
            color: #3525cd;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav class="d-flex gap-2 text-uppercase text-muted fw-bold mb-1" style="font-size: 0.75rem; letter-spacing: 0.1em;">
            <span style="color: #3525cd !important;">Members</span>
        </nav>
        <h2 class="fw-bold mb-0 text-dark" style="font-size: 1.75rem; letter-spacing: -0.02em;">Members Directory</h2>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-success py-3 shadow-sm rounded-3 mb-4" role="alert" style="background-color: #e6f8f0; color: #005236;">
        <span class="material-symbols-outlined">check_circle</span>
        <div class="fw-medium">@TempData["Success"]</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border: 1px solid #e9ecef !important;">
    <div class="table-responsive">
        <table class="table-modern">
            <thead>
                <tr>
                    <th style="min-width: 250px;">Member Identity</th>
                    <th>Contact Info</th>
                    <th>Location</th>
                    <th>System Access</th>
                    <th class="text-end">Management</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <div class="py-4">
                                <span class="material-symbols-outlined text-muted opacity-25" style="font-size: 4rem;">person_off</span>
                                <h5 class="fw-bold text-dark mt-3">No members registered</h5>
                                <p class="text-muted">New members will appear here once they join the library.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var member in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle shadow-sm">
                                        @(string.IsNullOrWhiteSpace(member.FullName) ? "?" : member.FullName.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark" style="font-family: 'Manrope', sans-serif;">@member.FullName</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">
                                            <span class="material-symbols-outlined" style="font-size: 0.85rem;">alternate_email</span>
                                            @(member.Account?.Username ?? "No account")
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <div class="d-flex align-items-center gap-2 small fw-medium">
                                        <span class="material-symbols-outlined text-muted" style="font-size: 1rem;">smartphone</span>
                                        @(member.Phone ?? "—")
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="text-muted small d-flex align-items-center gap-1" style="max-width: 180px;">
                                    <span class="material-symbols-outlined" style="font-size: 1rem;">location_on</span>
                                    <span class="text-truncate" title="@member.Address">@(member.Address ?? "Not specified")</span>
                                </div>
                            </td>
                            <td>
                                @{
                                    var roleName = member.Account?.Role?.Name ?? "User";
                                    var isAdmin = !roleName.Equals("User", StringComparison.OrdinalIgnoreCase);
                                }
                                <span class="badge-role @(isAdmin ? "admin" : "user")">
                                    <span class="material-symbols-outlined" style="font-size: 0.9rem;">
                                        @(isAdmin ? "verified_user" : "person")
                                    </span>
                                    @roleName
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Detail" asp-route-id="@member.Id" class="action-btn" title="View Profile">
                                        <span class="material-symbols-outlined">person_search</span>
                                    </a>

                                    @if (member.Account?.Role?.Name != "User")
                                    {
                                        <a asp-action="Edit" asp-route-id="@member.Id" class="action-btn" title="Edit Access">
                                            <span class="material-symbols-outlined" style="color: #d97706;">shield_person</span>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>