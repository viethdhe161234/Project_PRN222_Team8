@model LibraryManagement.Web.Models.EditMemberViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Member Profile";
}

<style>
    /* Styling cho Form đồng bộ với Curation Theme */
    .form-modern-card {
        border-radius: 1.25rem;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 25px -5px rgba(53, 37, 205, 0.05);
        max-width: 650px;
        background-color: #ffffff;
    }

    .custom-input {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.2s ease;
        color: #2d3748;
    }

        .custom-input:focus {
            background-color: #ffffff;
            border-color: #3525cd;
            box-shadow: 0 0 0 4px rgba(53, 37, 205, 0.1);
            outline: none;
        }

    .form-label-custom {
        font-weight: 700;
        color: #64748b;
        font-size: 0.75rem;
        margin-bottom: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    /* Các nút bấm (Buttons) */
    .btn-indigo {
        background-color: #3525cd;
        color: white;
        border: none;
        border-radius: 0.75rem;
        padding: 0.75rem 1.75rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-indigo:hover {
            background-color: #2a1da8;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(53, 37, 205, 0.2);
            color: white;
        }

    .btn-soft {
        background-color: #f1f3f5;
        color: #4a5568;
        border: none;
        border-radius: 0.75rem;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-soft:hover {
            background-color: #e9ecef;
            color: #2d3748;
        }

    .input-icon {
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.25rem;
        color: #94a3b8;
    }
</style>

<div class="mb-4">
    <nav class="d-flex gap-2 text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.1em;">
        <a asp-action="Index" class="text-decoration-none text-muted" onmouseover="this.style.color='#3525cd'" onmouseout="this.style.color='#6c757d'">Members</a>
        <span class="text-secondary">/</span>
        <span style="color: #3525cd !important;">Edit</span>
    </nav>
    <h2 class="fw-bold text-dark mb-1" style="letter-spacing: -0.02em;">Edit Member Profile</h2>
    <p class="text-muted mb-0">Update identity information and contact details for this library member.</p>
</div>

<div class="card form-modern-card border-0 shadow-sm">
    <div class="card-body p-4 p-md-5">
        <form asp-action="Edit" method="post">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-danger py-3 shadow-sm rounded-end-3 mb-4" role="alert" style="background-color: #ffdad6; color: #93000a;">
                    <span class="material-symbols-outlined fs-4 text-danger">error</span>
                    <div asp-validation-summary="ModelOnly" class="fw-medium mb-0"></div>
                </div>
            }

            <input asp-for="Id" type="hidden" />

            <div class="mb-4">
                <label asp-for="FullName" class="form-label-custom">Full Name</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute input-icon">person</span>
                    <input asp-for="FullName" class="form-control custom-input" style="padding-left: 3rem;" placeholder="e.g. John Doe" />
                </div>
                <span asp-validation-for="FullName" class="text-danger mt-2 d-block small fw-medium"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Phone" class="form-label-custom">Phone Number</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute input-icon">smartphone</span>
                    <input asp-for="Phone" class="form-control custom-input" style="padding-left: 3rem;" placeholder="e.g. 0987 654 321" />
                </div>
                <span asp-validation-for="Phone" class="text-danger mt-2 d-block small fw-medium"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Address" class="form-label-custom">Home Address</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute text-muted" style="left: 1rem; top: 1rem; font-size: 1.25rem; color: #94a3b8;">location_on</span>
                    <textarea asp-for="Address" class="form-control custom-input" style="padding-left: 3rem; min-height: 120px; padding-top: 1rem;" placeholder="Enter full residential address..."></textarea>
                </div>
                <span asp-validation-for="Address" class="text-danger mt-2 d-block small fw-medium"></span>
            </div>

            <div class="d-flex align-items-center gap-3 pt-4 border-top border-light">
                <button type="submit" class="btn-indigo d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem;">verified</span>
                    Update Profile
                </button>
                <a asp-action="Index" class="btn-soft text-decoration-none">Discard Changes</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}