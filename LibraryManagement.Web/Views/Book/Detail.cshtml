@model LibraryManagement.Domain.Entities.Book

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Book Detail";
}

<style>
    /* CSS hỗ trợ icon Material */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
        font-size: 1.1rem;
    }

    /* Thiết kế bảng dòng tách rời cho Editions */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }

        .table-custom tbody tr {
            transition: background-color 0.2s ease;
        }

            .table-custom tbody tr:hover {
                background-color: #f8f9fa;
            }

        .table-custom td {
            border-top: 1px solid #f1f3f5;
            border-bottom: 1px solid #f1f3f5;
            padding: 1rem;
            vertical-align: middle;
        }

            .table-custom td:first-child {
                border-left: 1px solid #f1f3f5;
                border-top-left-radius: 0.75rem;
                border-bottom-left-radius: 0.75rem;
            }

            .table-custom td:last-child {
                border-right: 1px solid #f1f3f5;
                border-top-right-radius: 0.75rem;
                border-bottom-right-radius: 0.75rem;
            }

    /* Hiệu ứng ẩn/hiện nút thao tác */
    .action-btns {
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .table-custom tbody tr:hover .action-btns {
        opacity: 1;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav class="d-flex gap-2 text-uppercase text-muted fw-bold mb-1" style="font-size: 0.75rem; letter-spacing: 0.1em;">
            
            <a asp-action="Index" class="text-decoration-none text-muted" onmouseover="this.style.color='#3525cd'" onmouseout="this.style.color='#6c757d'" style="transition: color 0.2s;">Books</a>
            <span class="text-secondary">/</span>
            <span style="color: #3525cd !important;">Detail</span>
        </nav>
        <h2 class="fw-bold mb-0 text-dark" style="font-size: 1.75rem; letter-spacing: -0.02em;">Book Profile</h2>
    </div>
    <a asp-action="Index" class="btn btn-light px-3 py-2 fw-semibold rounded-2 d-flex align-items-center gap-2 border shadow-sm" style="font-size: 0.95rem;">
        <span class="material-symbols-outlined" style="font-size: 1.2rem;">arrow_back</span>
        Back to Catalog
    </a>
</div>

<div class="mb-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-success py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #e6f8f0; color: #005236;">
            <span class="material-symbols-outlined fs-4">check_circle</span>
            <div class="fw-medium mb-0">@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-danger py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #ffdad6; color: #93000a;">
            <span class="material-symbols-outlined fs-4 text-danger">error</span>
            <div class="fw-medium mb-0">@TempData["Error"]</div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm rounded-4 mb-5" style="background-color: #ffffff;">
    <div class="card-body p-4 p-md-5 d-flex flex-column flex-md-row gap-4 gap-md-5">
        <div class="flex-shrink-0 mx-auto mx-md-0 text-center">
            @if (!string.IsNullOrEmpty(Model.CoverImage))
            {
                <img src="@Model.CoverImage" alt="cover" class="rounded-3 shadow" style="width: 160px; height: 230px; object-fit: cover; border: 4px solid #fff;" />
            }
            else
            {
                <div class="rounded-3 d-flex flex-column align-items-center justify-content-center shadow-sm" style="width: 160px; height: 230px; background-color: #f8f9fa; color: #adb5bd; border: 4px solid #fff;">
                    <span class="material-symbols-outlined mb-2" style="font-size: 3rem;">auto_stories</span>
                    <span class="fw-medium" style="font-size: 0.85rem;">No Image</span>
                </div>
            }
        </div>

        <div class="flex-grow-1 d-flex flex-column justify-content-center">
            <h3 class="fw-bolder text-dark mb-3" style="font-family: 'Manrope', sans-serif;">@Model.Title</h3>

            <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
                <strong class="text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.05em; width: 80px;">Authors</strong>
                @foreach (var ba in Model.BookAuthors)
                {
                    <span class="badge rounded-pill fw-medium px-3 py-2" style="background-color: #f4f2ff; color: #3525cd; border: 1px solid #e2dfff;">@ba.Author.Name</span>
                }
            </div>

            <div class="mb-4 d-flex flex-wrap gap-2 align-items-center">
                <strong class="text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.05em; width: 80px;">Categories</strong>
                @foreach (var bc in Model.BookCategories)
                {
                    <span class="badge rounded-pill fw-medium px-3 py-2" style="background-color: #f8f9fa; color: #495057; border: 1px solid #dee2e6;">@bc.Category.Name</span>
                }
            </div>

            <div class="mb-4">
                <strong class="text-uppercase text-muted d-block mb-2" style="font-size: 0.75rem; letter-spacing: 0.05em;">Synopsis</strong>
                <p class="text-secondary mb-0" style="line-height: 1.6; font-size: 0.95rem;">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available for this book." : Model.Description)
                </p>
            </div>

            <div class="mt-auto pt-3 border-top border-light-subtle">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn px-4 py-2 fw-semibold rounded-3 d-inline-flex align-items-center gap-2" style="background-color: #3525cd; color: #fff; transition: all 0.2s;" onmouseover="this.style.filter='brightness(0.9)'" onmouseout="this.style.filter='brightness(1)'">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem;">edit</span>
                    Edit Book Profile
                </a>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-3 px-2">
    <div>
        <h4 class="fw-bold mb-1 text-dark" style="font-family: 'Manrope', sans-serif;">Editions & Copies</h4>
        <p class="text-muted small mb-0">Manage publishing versions and physical copies of this book.</p>
    </div>
    <a asp-controller="BookEdition" asp-action="Create" asp-route-bookId="@Model.Id" class="btn px-3 py-2 fw-semibold rounded-3 d-flex align-items-center gap-2 text-white shadow-sm" style="background-color: #198754; transition: all 0.2s;" onmouseover="this.style.filter='brightness(0.9)'" onmouseout="this.style.filter='brightness(1)'">
        <span class="material-symbols-outlined">library_books</span>
        Add Edition
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4" style="background-color: #fcfcff;">
    <div class="card-body p-3">
        <table class="table table-borderless table-custom mb-0">
            <thead>
                <tr class="text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    <th class="px-4">Publisher</th>
                    <th class="px-3 text-center" style="width: 120px;">Year</th>
                    <th class="px-3 text-center" style="width: 120px;">Copies</th>
                    <th class="px-4 text-end" style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Editions.Any())
                {
                    <tr>
                        <td colspan="4" class="px-4 py-5 text-center text-muted bg-white rounded-3">
                            <span class="material-symbols-outlined fs-1 mb-2 opacity-50">book_2</span>
                            <p class="mb-0 fw-medium">No editions have been added yet.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var edition in Model.Editions)
                    {
                        <tr class="bg-white">
                            <td class="px-4 fw-bold text-dark">@edition.Publisher</td>
                            <td class="px-3 text-center text-muted">@edition.PublishYear</td>
                            <td class="px-3 text-center">
                                <span class="badge rounded-pill border fw-bold px-3 py-1" style="background-color: #f8f9fa; color: #495057; border-color: #dee2e6 !important;">
                                    @edition.Copies.Count()
                                </span>
                            </td>
                            <td class="px-4 text-end">
                                <div class="action-btns d-flex justify-content-end gap-2">
                                    <a asp-controller="BookCopy" asp-action="Index" asp-route-editionId="@edition.Id"
                                       class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border"
                                       style="width: 36px; height: 36px; background-color: #ffffff; color: #0d9488; border-color: #ccfbf1 !important; transition: all 0.2s;"
                                       onmouseover="this.style.backgroundColor='#f0fdfa'; this.style.borderColor='#0d9488 !important';"
                                       onmouseout="this.style.backgroundColor='#ffffff'; this.style.borderColor='#ccfbf1 !important';"
                                       title="Manage Copies">
                                        <span class="material-symbols-outlined" style="font-size: 1.1rem;">inventory_2</span>
                                    </a>

                                    <a asp-controller="BookEdition" asp-action="Edit" asp-route-id="@edition.Id"
                                       class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border"
                                       style="width: 36px; height: 36px; background-color: #ffffff; color: #3525cd; border-color: #e2dfff !important; transition: all 0.2s;"
                                       onmouseover="this.style.backgroundColor='#f4f2ff'; this.style.borderColor='#3525cd !important';"
                                       onmouseout="this.style.backgroundColor='#ffffff'; this.style.borderColor='#e2dfff !important';"
                                       title="Edit Edition">
                                        <span class="material-symbols-outlined" style="font-size: 1.1rem;">edit</span>
                                    </a>

                                    <form asp-controller="BookEdition" asp-action="Delete" asp-route-id="@edition.Id" method="post" class="m-0 d-inline-flex" onsubmit="return confirm('Are you sure you want to delete this edition?')">
                                        <button type="submit"
                                                class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border p-0"
                                                style="width: 36px; height: 36px; background-color: #ffffff; color: #dc3545; border-color: #f8d7da !important; transition: all 0.2s;"
                                                onmouseover="this.style.backgroundColor='#fff5f5'; this.style.color='#bd2130';"
                                                onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#dc3545';"
                                                title="Delete Edition">
                                            <span class="material-symbols-outlined" style="font-size: 1.1rem;">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>