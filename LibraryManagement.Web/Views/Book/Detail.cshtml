@model LibraryManagement.Domain.Entities.Book

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Book Detail";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Book Info -->
<div class="card mb-4">
    <div class="card-body d-flex gap-4">
        <div>
            @if (!string.IsNullOrEmpty(Model.CoverImage))
            {
                <img src="@Model.CoverImage" alt="cover"
                     style="width:100px; height:140px; object-fit:cover;" />
            }
            else
            {
                <div style="width:100px; height:140px; background:#e5e7eb;
                            display:flex; align-items:center; justify-content:center; color:#9ca3af;">
                    No image
                </div>
            }
        </div>
        <div>
            <h4>@Model.Title</h4>
            <p class="text-muted mb-1">
                <strong>Authors:</strong>
                @string.Join(", ", Model.BookAuthors.Select(ba => ba.Author.Name))
            </p>
            <p class="text-muted mb-1">
                <strong>Categories:</strong>
                @string.Join(", ", Model.BookCategories.Select(bc => bc.Category.Name))
            </p>
            <p class="text-muted">@Model.Description</p>
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-sm btn-outline-primary">Edit Book</a>
        </div>
    </div>
</div>

<!-- Editions -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Editions</h5>
    <a asp-controller="BookEdition" asp-action="Create" asp-route-bookId="@Model.Id"
       class="btn btn-primary btn-sm">+ Add Edition</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Publisher</th>
                    <th>Year</th>
                    <th>Copies</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var edition in Model.Editions)
                {
                    <tr>
                        <td>@edition.Publisher</td>
                        <td>@edition.PublishYear</td>
                        <td>@edition.Copies.Count()</td>
                        <td>
                            <a asp-controller="BookCopy" asp-action="Index"
                               asp-route-editionId="@edition.Id"
                               class="btn btn-sm btn-outline-info">Copies</a>
                            <a asp-controller="BookEdition" asp-action="Edit"
                               asp-route-id="@edition.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-controller="BookEdition" asp-action="Delete"
                                  asp-route-id="@edition.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this edition?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Editions.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No editions found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>