@model IEnumerable<LibraryManagement.Domain.Entities.Book>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Books";
}

<style>
    /* CSS hỗ trợ icon Material và căn chỉnh giao diện bảng */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
        font-size: 1.1rem;
    }

    /* Thiết kế bảng dòng tách rời */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }

        .table-custom tbody tr {
            transition: background-color 0.2s ease;
        }

            .table-custom tbody tr:hover {
                background-color: #f8f9fa;
            }

        .table-custom td {
            border-top: 1px solid #f1f3f5;
            border-bottom: 1px solid #f1f3f5;
            padding: 1rem;
            vertical-align: middle;
        }

            .table-custom td:first-child {
                border-left: 1px solid #f1f3f5;
                border-top-left-radius: 0.75rem;
                border-bottom-left-radius: 0.75rem;
            }

            .table-custom td:last-child {
                border-right: 1px solid #f1f3f5;
                border-top-right-radius: 0.75rem;
                border-bottom-right-radius: 0.75rem;
            }

    /* Hiệu ứng ẩn/hiện nút thao tác khi di chuột vào hàng */
    .action-btns {
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .table-custom tbody tr:hover .action-btns {
        opacity: 1;
    }
</style>

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <nav class="d-flex gap-2 text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.1em;">
            
            <span class="text-primary" style="color: #3525cd !important;">Books</span>
        </nav>
        <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.25rem; font-family: 'Manrope', sans-serif;">Books</h2>
    </div>
    <a asp-action="Create" class="btn px-4 py-2 fw-semibold rounded-3 d-flex align-items-center gap-2 text-white shadow-sm" style="background-color: #3525cd; transition: all 0.2s;" onmouseover="this.style.filter='brightness(0.9)'" onmouseout="this.style.filter='brightness(1)'">
        <span class="material-symbols-outlined">library_add</span>
        Add Book
    </a>
</div>

<div class="mb-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-success py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #e6f8f0; color: #005236;">
            <span class="material-symbols-outlined fs-4">check_circle</span>
            <div class="fw-medium mb-0">@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 border-danger py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #ffdad6; color: #93000a;">
            <span class="material-symbols-outlined fs-4 text-danger">error</span>
            <div class="fw-medium mb-0">@TempData["Error"]</div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm rounded-4" style="background-color: #fcfcff;">
    <div class="card-body p-3">
        <table class="table table-borderless table-custom mb-0">
            <thead>
                <tr class="text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    <th class="px-4 text-center" style="width: 80px;">Cover</th>
                    <th class="px-3">Title</th>
                    <th class="px-3">Authors</th>
                    <th class="px-3">Categories</th>
                    <th class="px-3 text-center" style="width: 100px;">Editions</th>
                    <th class="px-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-4 py-5 text-center text-muted bg-white rounded-3">
                            <span class="material-symbols-outlined fs-1 mb-2 opacity-50">auto_stories</span>
                            <p class="mb-0 fw-medium">No books found in the archive.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var book in Model)
                    {
                        <tr class="bg-white">
                            <td class="px-4 text-center">
                                @if (!string.IsNullOrEmpty(book.CoverImage))
                                {
                                    <img src="@book.CoverImage" alt="cover" class="rounded-2 shadow-sm" style="width: 44px; height: 60px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="rounded-2 d-flex align-items-center justify-content-center mx-auto" style="width: 44px; height: 60px; background-color: #f1f3f5; color: #adb5bd;">
                                        <span class="material-symbols-outlined" style="font-size: 1.5rem;">auto_stories</span>
                                    </div>
                                }
                            </td>

                            <td class="px-3">
                                <span class="fw-bold fs-6 text-dark" style="font-family: 'Manrope', sans-serif;">@book.Title</span>
                            </td>

                            <td class="px-3 text-muted" style="font-size: 0.9rem;">
                                @string.Join(", ", book.BookAuthors.Select(ba => ba.Author.Name))
                            </td>

                            <td class="px-3 text-muted" style="font-size: 0.9rem;">
                                @string.Join(", ", book.BookCategories.Select(bc => bc.Category.Name))
                            </td>

                            <td class="px-3 text-center">
                                <span class="badge rounded-pill border fw-bold px-2 py-1" style="background-color: #f8f9fa; color: #495057; border-color: #dee2e6 !important;">
                                    @book.Editions.Count()
                                </span>
                            </td>

                            <td class="px-4 text-end">
                                <div class="action-btns d-flex justify-content-end gap-2">
                                    <a asp-action="Detail" asp-route-id="@book.Id"
                                       class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border"
                                       style="width: 36px; height: 36px; background-color: #ffffff; color: #0891b2; border-color: #cffafe !important; transition: all 0.2s;"
                                       onmouseover="this.style.backgroundColor='#ecfeff'; this.style.borderColor='#0891b2 !important';"
                                       onmouseout="this.style.backgroundColor='#ffffff'; this.style.borderColor='#cffafe !important';"
                                       title="View Details">
                                        <span class="material-symbols-outlined" style="font-size: 1.1rem;">visibility</span>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@book.Id"
                                       class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border"
                                       style="width: 36px; height: 36px; background-color: #ffffff; color: #3525cd; border-color: #e2dfff !important; transition: all 0.2s;"
                                       onmouseover="this.style.backgroundColor='#f4f2ff'; this.style.borderColor='#3525cd !important';"
                                       onmouseout="this.style.backgroundColor='#ffffff'; this.style.borderColor='#e2dfff !important';"
                                       title="Edit Book">
                                        <span class="material-symbols-outlined" style="font-size: 1.1rem;">edit</span>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@book.Id" method="post" class="m-0 d-inline-flex" onsubmit="return confirm('Are you sure you want to delete this book?')">
                                        <button type="submit"
                                                class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 shadow-sm border p-0"
                                                style="width: 36px; height: 36px; background-color: #ffffff; color: #dc3545; border-color: #f8d7da !important; transition: all 0.2s;"
                                                onmouseover="this.style.backgroundColor='#fff5f5'; this.style.color='#bd2130';"
                                                onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#dc3545';"
                                                title="Delete Book">
                                            <span class="material-symbols-outlined" style="font-size: 1.1rem;">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>