@model IEnumerable<LibraryManagement.Domain.Entities.Category>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Categories";
}

<style>
    /* CSS hỗ trợ icon Material và căn chỉnh giao diện bảng */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
        font-size: 1.1rem;
    }

    /* Thiết kế riêng cho bảng để các dòng tách rời nhau */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }

        .table-custom tbody tr {
            transition: all 0.2s ease;
        }

            .table-custom tbody tr:hover {
                background-color: #f8f7ff !important; /* Màu tím cực nhạt khi hover */
                transform: translateY(-1px);
            }

        .table-custom td {
            border-top: 1px solid #f1f3f5;
            border-bottom: 1px solid #f1f3f5;
            padding: 1.1rem 1rem;
            vertical-align: middle;
        }

            .table-custom td:first-child {
                border-left: 1px solid #f1f3f5;
                border-top-left-radius: 0.75rem;
                border-bottom-left-radius: 0.75rem;
            }

            .table-custom td:last-child {
                border-right: 1px solid #f1f3f5;
                border-top-right-radius: 0.75rem;
                border-bottom-right-radius: 0.75rem;
            }

    /* Hiệu ứng ẩn/hiện nút thao tác */
    .action-btns {
        opacity: 0.5;
        transition: opacity 0.2s;
    }

    .table-custom tbody tr:hover .action-btns {
        opacity: 1;
    }

    /* Badge ID phong cách mã hệ thống */
    .id-badge {
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 0.8rem;
        color: #6c757d;
        background: #f1f3f5;
        padding: 0.2rem 0.5rem;
        border-radius: 0.4rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav class="d-flex gap-2 text-uppercase text-muted fw-bold mb-1" style="font-size: 0.75rem; letter-spacing: 0.1em;">
           
            <span style="color: #3525cd !important;">Categories</span>
        </nav>
        <h2 class="fw-bold mb-0 text-dark" style="font-size: 1.75rem; letter-spacing: -0.02em;">Genres & Classifications</h2>
    </div>
    <a asp-action="Create" class="btn text-white px-4 py-2 fw-semibold rounded-3 d-flex align-items-center gap-2 shadow-sm" style="background-color: #3525cd; transition: all 0.2s;" onmouseover="this.style.filter='brightness(1.1)'" onmouseout="this.style.filter='brightness(1)'">
        <span class="material-symbols-outlined">add_box</span>
        Add New Category
    </a>
</div>

<div class="mb-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 border-0 border-start border-4 py-3 shadow-sm rounded-end-3" role="alert" style="background-color: #e6f8f0; color: #005236; border-color: #059669 !important;">
            <span class="material-symbols-outlined fs-4">check_circle</span>
            <div class="fw-medium mb-0">@TempData["Success"]</div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm rounded-4" style="background-color: #fcfcff; border: 1px solid #e9ecef !important;">
    <div class="card-body p-3">
        <table class="table table-borderless table-custom mb-0">
            <thead>
                <tr class="text-muted fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    <th class="px-4" style="width: 100px;">Identifier</th>
                    <th class="px-4">Classification Name</th>
                    <th class="px-4 text-end" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="px-4 py-5 text-center text-muted bg-white rounded-4 shadow-sm border">
                            <span class="material-symbols-outlined mb-2 opacity-25" style="font-size: 4rem;">inventory_2</span>
                            <p class="mb-0 fw-medium">The library has no categories yet.</p>
                            <a asp-action="Create" class="btn btn-link text-decoration-none mt-2 fw-bold" style="color: #3525cd;">Get started by adding one</a>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="bg-white shadow-sm border-light">
                            <td class="px-4">
                                <span class="id-badge">#@item.Id.ToString("D3")</span>
                            </td>

                            <td class="px-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-none border" style="width: 42px; height: 42px; background-color: #f8f9fa; color: #3525cd;">
                                        <span class="material-symbols-outlined" style="font-size: 1.2rem;">label</span>
                                    </div>
                                    <span class="fw-bold fs-6 text-dark" style="font-family: 'Manrope', sans-serif;">@item.Name</span>
                                </div>
                            </td>

                            <td class="px-4 text-end">
                                <div class="action-btns d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 border p-0"
                                       style="width: 36px; height: 36px; background-color: #ffffff; color: #3525cd; transition: all 0.2s;"
                                       onmouseover="this.style.backgroundColor='#e2dfff'; this.style.borderColor='#3525cd';"
                                       onmouseout="this.style.backgroundColor='#ffffff'; this.style.borderColor='#dee2e6';"
                                       title="Edit">
                                        <span class="material-symbols-outlined" style="font-size: 1.1rem;">edit</span>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Archive the category @item.Name?')">
                                        <button type="submit"
                                                class="btn btn-sm d-flex align-items-center justify-content-center rounded-2 border p-0"
                                                style="width: 36px; height: 36px; background-color: #ffffff; color: #dc3545; transition: all 0.2s;"
                                                onmouseover="this.style.backgroundColor='#fff5f5'; this.style.borderColor='#dc3545';"
                                                onmouseout="this.style.backgroundColor='#ffffff'; this.style.borderColor='#dee2e6';"
                                                title="Delete">
                                            <span class="material-symbols-outlined" style="font-size: 1.1rem;">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>