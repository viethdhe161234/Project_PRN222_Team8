@using Microsoft.AspNetCore.Http
@{
    var username = Context.Session.GetString("Username");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Librarian Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

    <style>
        :root {
            --sidebar-width: 260px;
            --primary-dark: #0f172a;
            --accent-blue: #3b82f6;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
            min-height: 100vh;
        }

        /* Sidebar hiện đại */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--primary-dark);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            transition: all 0.3s;
            box-shadow: 4px 0 10px rgba(0,0,0,0.05);
        }

        .sidebar-brand {
            padding: 24px;
            display: flex;
            align-items: center;
            color: #fff;
            text-decoration: none;
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: -0.5px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-section {
            padding: 24px 24px 8px;
            font-size: 0.65rem;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-link {
            padding: 12px 24px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
        }

            .nav-link:hover {
                color: #fff;
                background: rgba(255,255,255,0.05);
            }

            /* Logic Active của bạn giữ nguyên */
            .nav-link.active {
                color: #fff;
                background: var(--accent-blue);
                box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
            }

            .nav-link .material-symbols-outlined {
                font-size: 20px;
            }

        /* Topbar sạch sẽ */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .topbar {
            height: 70px;
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 0 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .page-title {
            font-weight: 700;
            color: #1e293b;
            margin: 0;
        }

        .content-area {
            padding: 32px;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-left: 16px;
            border-left: 1px solid #e2e8f0;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a class="sidebar-brand" asp-controller="Librarian" asp-action="Dashboard">
            <span class="material-symbols-outlined me-2 text-primary">auto_stories</span>
            <span>LIBRARIAN</span>
        </a>

        <div class="nav flex-column mt-3">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Librarian" asp-action="Dashboard">
                <span class="material-symbols-outlined">dashboard</span> Dashboard
            </a>

            <div class="nav-section">Borrow Management</div>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "PendingRequests" ? "active" : "")"
               asp-controller="Librarian" asp-action="PendingRequests">
                <span class="material-symbols-outlined">pending_actions</span> Pending Requests
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ActiveLoans" ? "active" : "")"
               asp-controller="Librarian" asp-action="ActiveLoans">
                <span class="material-symbols-outlined">book_2</span> Active Loans
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "OverdueLoans" ? "active" : "")"
               asp-controller="Librarian" asp-action="OverdueLoans">
                <span class="material-symbols-outlined">history_toggle_off</span> Overdue
                @* Logic hiện Badge của bạn *@
                @if (ViewBag.OverdueCount != null && ViewBag.OverdueCount > 0)
                {
                    <span class="badge rounded-pill bg-danger ms-auto">@ViewBag.OverdueCount</span>
                }
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="topbar">
            <h5 class="page-title">@ViewData["Title"]</h5>

            <div class="d-flex align-items-center">
                <div class="user-profile">
                    <div class="text-end me-3">
                        <div class="small fw-800 text-dark">@username</div>
                        <div class="small text-muted" style="font-size: 0.7rem;">Administrator</div>
                    </div>
                    <a asp-controller="Account" asp-action="Logout"
                       class="btn btn-sm btn-light text-danger fw-bold border">
                        Logout
                    </a>
                </div>
            </div>
        </div>

        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>