@using Microsoft.AspNetCore.Http
@{
    var username = Context.Session.GetString("Username") ?? "Administrator";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Atelier</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        /* Typography & Base Colors */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc; /* Màu nền xám xanh siêu nhạt cho độ tương phản tốt hơn */
            color: #0f172a;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6, .font-headline {
            font-family: 'Manrope', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
            font-size: 1.25rem;
        }

        /* --- Sidebar Styling --- */
        .sidebar {
            min-height: 100vh;
            width: 260px;
            background-color: #0f172a; /* Slate 900 */
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 24px rgba(0,0,0,0.06);
            transition: transform 0.3s ease;
        }

        .sidebar-brand-container {
            padding: 1.5rem 1.25rem 2rem;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            transition: opacity 0.2s;
        }

            .sidebar-brand:hover {
                opacity: 0.9;
            }

        .brand-icon {
            width: 42px;
            height: 42px;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.4);
        }

        .brand-text h1 {
            color: white;
            font-size: 1.25rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.025em;
        }

        .brand-text p {
            color: #94a3b8;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin: 0;
            font-weight: 600;
        }

        /* Nav Links */
        .sidebar-scroll-area {
            flex-grow: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding-bottom: 2rem;
        }

            /* Tùy chỉnh thanh cuộn cho sidebar */
            .sidebar-scroll-area::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-scroll-area::-webkit-scrollbar-thumb {
                background: #334155;
                border-radius: 4px;
            }

        .sidebar .nav-link {
            color: #94a3b8;
            padding: 0.75rem 1.25rem;
            margin: 0.25rem 1rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.85rem;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s ease;
            text-decoration: none;
        }

            .sidebar .nav-link:hover {
                color: white;
                background-color: rgba(255, 255, 255, 0.05);
                transform: translateX(4px);
            }

            /* Active State Gradient */
            .sidebar .nav-link.active {
                color: white;
                background: linear-gradient(90deg, #4f46e5, #6366f1);
                box-shadow: 0 4px 15px rgba(79, 70, 229, 0.25);
                font-weight: 600;
                transform: none;
            }

        .sidebar .nav-section {
            color: #475569;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            padding: 1.5rem 1.5rem 0.5rem;
        }

        /* --- Main Content & Topbar --- */
        .main-content {
            margin-left: 260px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }

        .topbar {
            background-color: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 0.75rem 2.5rem;
            display: flex;
            justify-content: flex-end; /* Đẩy cụm User Profile sang sát mép phải */
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 900;
            border-bottom: 1px solid rgba(0,0,0,0.03);
            height: 72px;
        }

        .content-area {
            padding: 2.5rem;
            flex-grow: 1;
        }

        /* User Menu */
        .user-profile-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
            padding: 0.25rem 0.5rem;
            border-radius: 50rem;
            transition: background-color 0.2s;
        }

            .user-profile-btn:hover {
                background-color: #f1f5f9;
            }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand-container">
            <a class="sidebar-brand" asp-controller="Admin" asp-action="Dashboard">
                <div class="brand-icon">
                    <span class="material-symbols-outlined">auto_awesome</span>
                </div>
                <div class="brand-text">
                    <h1>Library </h1>
                    <p>Admin Workspace</p>
                </div>
            </a>
        </div>

        <div class="sidebar-scroll-area">
            <a class="nav-link @(currentController == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                Dashboard
            </a>

            <div class="nav-section">People</div>
            <a class="nav-link @(currentController == "Account" ? "active" : "")" asp-controller="Account" asp-action="Index">
                <span class="material-symbols-outlined">manage_accounts</span>
                Accounts
            </a>
            <a class="nav-link @(currentController == "Member" ? "active" : "")" asp-controller="Member" asp-action="Index">
                <span class="material-symbols-outlined">badge</span>
                Member Info
            </a>

            <div class="nav-section">Catalog</div>
            <a class="nav-link @(currentController == "Book" ? "active" : "")" asp-controller="Book" asp-action="Index">
                <span class="material-symbols-outlined">library_books</span>
                Books
            </a>
            <a class="nav-link @(currentController == "Author" ? "active" : "")" asp-controller="Author" asp-action="Index">
                <span class="material-symbols-outlined">history_edu</span>
                Authors
            </a>
            <a class="nav-link @(currentController == "Category" ? "active" : "")" asp-controller="Category" asp-action="Index">
                <span class="material-symbols-outlined">style</span>
                Categories
            </a>

            <div class="nav-section">System</div>
            <a class="nav-link @(currentController == "BorrowPolicy" ? "active" : "")" asp-controller="BorrowPolicy" asp-action="Index">
                <span class="material-symbols-outlined">rule_settings</span>
                Borrow Policy
            </a>
        </div>

        <div class="p-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
            <a class="nav-link text-danger m-0" asp-controller="Account" asp-action="Logout" style="padding: 0.75rem; border-radius: 0.75rem;">
                <span class="material-symbols-outlined" style="color: #ef4444;">logout</span>
                <span class="fw-bold" style="color: #ef4444;">Sign Out</span>
            </a>
        </div>
    </aside>

    <main class="main-content">

        <header class="topbar">

            <div class="d-flex align-items-center gap-4">
                <div class="position-relative" style="cursor: pointer;">
                    <span class="material-symbols-outlined text-secondary" style="transition: color 0.2s;">notifications</span>
                    <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                </div>

                <div class="user-profile-btn">
                    <div class="text-end d-none d-md-block">
                        <p class="mb-0 fw-bolder text-dark" style="font-size: 0.85rem; font-family: 'Manrope', sans-serif;">@username</p>
                        <p class="mb-0 text-muted" style="font-size: 0.7rem; font-weight: 500;">System Admin</p>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; font-weight: 700; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; font-size: 1.1rem;">
                        @(username.Substring(0, 1).ToUpper())
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">
            @RenderBody()
        </div>

    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>