@using Microsoft.AspNetCore.Http
@{
    var username = Context.Session.GetString("Username");
    var role = Context.Session.GetString("Role");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Scholarly Curator</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary-indigo: #3525cd;
            --soft-surface: #faf8ff;
            --text-dark: #131b2e;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--soft-surface);
            color: var(--text-dark);
        }

        .font-headline {
            font-family: 'Manrope', sans-serif;
        }

        /* Custom Navbar phong cách Atelier */
        .navbar-atelier {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #edf2f7;
            padding: 0.75rem 0;
        }

        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 1rem !important;
            transition: all 0.2s;
        }

            .nav-link:hover {
                color: var(--primary-indigo) !important;
            }

        /* Badge Giỏ hàng */
        .cart-badge {
            background-color: #ba1a1a;
            font-size: 0.65rem;
            padding: 0.25em 0.5em;
            border-radius: 50rem;
            position: absolute;
            top: 2px;
            right: 0;
        }

        /* User Profile Area */
        .user-profile-section {
            border-left: 1px solid #eee;
            padding-left: 1.5rem;
        }

        .avatar-circle {
            width: 38px;
            height: 38px;
            background: #eef0ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-indigo);
            border: 2px solid white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .dropdown-menu {
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border-radius: 12px;
            padding: 0.5rem;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 0.6rem 1rem;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .btn-indigo {
            background-color: var(--primary-indigo);
            color: white;
            border-radius: 10px;
            font-weight: 600;
            padding: 0.5rem 1.25rem;
            border: none;
        }

            .btn-indigo:hover {
                background-color: #2a1da8;
                color: white;
                box-shadow: 0 4px 12px rgba(53, 37, 205, 0.2);
            }

        footer {
            background: white;
            border-top: 1px solid #eee;
            padding: 3rem 0;
            margin-top: 5rem;
        }

        .material-symbols-outlined {
            vertical-align: middle;
            font-size: 1.25rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top navbar-atelier">
        <div class="container">
            <a class="navbar-brand font-headline fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index" style="color: var(--text-dark);">
                <span class="fs-4">📚</span> <span class="tracking-tight">Scholarly Curator</span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="material-symbols-outlined">menu</span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Books">Books</a>
                    </li>

                    @if (username != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link position-relative pe-3" asp-controller="Cart" asp-action="Index">
                                Cart
                                @{
                                    var cart = Context.Session.GetString("Cart");
                                    var cartCount = string.IsNullOrEmpty(cart) ? 0
                                    : System.Text.Json.JsonSerializer.Deserialize<List<int>>(cart)?.Count ?? 0;
                                }
                                @if (cartCount > 0)
                                {
                                    <span class="badge cart-badge">@cartCount</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="BorrowRequest" asp-action="Index">My Requests</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Loan" asp-action="Index">My Loans</a>
                        </li>
                    }
                </ul>

                <div class="d-flex align-items-center gap-3">
                    @if (username != null)
                    {
                        <div class="user-profile-section d-flex align-items-center gap-3">
                            <div class="text-end d-none d-sm-block">
                                <p class="text-uppercase fw-bold text-muted mb-0" style="font-size: 0.65rem; letter-spacing: 0.05em;">@role</p>
                                <p class="fw-bold mb-0 text-dark small">@username</p>
                            </div>

                            <div class="dropdown">
                                <a href="#" class="d-block link-dark text-decoration-none" data-bs-toggle="dropdown">
                                    <div class="avatar-circle">
                                        <span class="material-symbols-outlined">person</span>
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Profile" asp-action="Index">
                                            <span class="material-symbols-outlined fs-5">account_circle</span> My Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li>
                                        <a class="dropdown-item text-danger d-flex align-items-center gap-2" asp-controller="Account" asp-action="Logout">
                                            <span class="material-symbols-outlined fs-5">logout</span> Logout
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-link text-decoration-none text-muted fw-bold small">Login</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-indigo shadow-sm">Register</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-4 min-vh-100">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <h5 class="font-headline fw-bold mb-1">Scholarly Curator</h5>
                    <p class="text-muted small mb-0">© 2026 - Library Management System. Crafted for The Atelier.</p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <div class="d-flex justify-content-center justify-content-md-end gap-3 text-muted">
                        <span class="material-symbols-outlined cursor-pointer">share</span>
                        <span class="material-symbols-outlined cursor-pointer">verified_user</span>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>